{
  "name": "soilprofiles",
  "version": "0.1.2",
  "description": "TypeScript library for managing and rendering soil profile data in the browser or Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./three3d": {
      "types": "./dist/render/three3d.d.ts",
      "require": "./dist/render/three3d.js",
      "default": "./dist/render/three3d.js"
    }
  },
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "demo:web": "node examples/serve-demo.js"
  },
  "keywords": [
    "soil",
    "soil-profile",
    "soil-science",
    "rendering",
    "three"
  ],
  "author": {
    "name": "Andrew Brown",
    "email": "brown.andrewg@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brownag/SoilProfiles.js"
  },
  "homepage": "https://github.com/brownag/SoilProfiles.js#readme",
  "bugs": {
    "url": "https://github.com/brownag/SoilProfiles.js/issues"
  },
  "type": "commonjs",
  "peerDependencies": {
    "three": "^0.185.1"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/three": "^0.184.1",
    "canvas": "^3.2.3",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "three": "^0.185.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "canvas@3.2.3": true,
    "esbuild@0.28.1": true,
    "unrs-resolver@1.12.2": true
  }
}
